<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Redirecting...</title>
    <script>
        const targetPath = "user/user-menu.html";
        // Directly append the target path to the current origin and path
        // This keeps it relative to your root repository directory
        window.location.replace(window.location.href.split('?')[0].replace(/\/$/, "") + "/" + targetPath);
    </script>
</head>
<body>
    <p>Redirecting...</p>
</body>
</html>
